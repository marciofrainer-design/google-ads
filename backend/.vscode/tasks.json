{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tsc: build",
      "type": "shell",
      "command": "node_modules/.bin/tsc --project tsconfig.json",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "tsc: watch",
      "type": "shell",
      "command": "node_modules/.bin/tsc --project tsconfig.json --watch --preserveWatchOutput",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"],
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    }
  ]
}
