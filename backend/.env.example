# Servidor
PORT=3001
NODE_ENV=development

# Google Ads API - Credenciais OAuth2
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# ID da conta Google Ads (Manager Account ou Customer Account)
GOOGLE_ADS_CUSTOMER_ID=your_customer_id_here
# Caso use Manager Account (MCC), preencha também:
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_mcc_customer_id_here

# CORS - origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT para sessões internas (opcional)
JWT_SECRET=change_this_to_a_random_secret
JWT_EXPIRES_IN=7d
