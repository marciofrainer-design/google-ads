{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite:dev",
      "type": "process",
      "command": "/home/usuario/.nvm/versions/node/v24.14.0/bin/node",
      "args": [
        "/home/usuario/.nvm/versions/node/v24.14.0/lib/node_modules/npm/bin/npm-cli.js",
        "run",
        "dev",
        "--",
        "--port",
        "5173",
        "--strictPort"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(ERROR|WARN)\\s+(.*)$",
          "severity": 1,
          "message": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Local:\\s+http://localhost:5173/"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "/home/usuario/.nvm/versions/node/v24.14.0/bin:${env:PATH}"
        }
      }
    }
  ]
}
